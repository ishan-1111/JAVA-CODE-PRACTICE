public class LargestNumber {
    public static void main(String[] args) {
        int[] numbers = {10, 25, 3, 42, 18};
        int max = numbers[0];
        
        for (int num : numbers) {
            if (num > max) {
                max = num;
            }
        }
        
        System.out.println("Largest number: " + max);
    }
}

